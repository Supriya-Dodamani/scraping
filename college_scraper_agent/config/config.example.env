# =============================================
# College Scraper Agent - Configuration
# Copy this file to .env and fill in your keys
# =============================================

# --- AI Provider (choose one) ---
# Option A: Groq (FREE - recommended)
GROQ_API_KEY=your_groq_api_key_here

# Option B: OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# --- Search API (optional but recommended) ---
# SerpAPI - for Google search (free tier available)
SERPAPI_KEY=your_serpapi_key_here

# --- Scraper Settings ---
REQUEST_DELAY=2          # seconds between requests
MAX_RETRIES=3
TIMEOUT=30
MAX_COLLEGES=100         # max colleges to scrape per run

# --- Output ---
OUTPUT_DIR=output
OUTPUT_FORMAT=csv,json,xlsx   # comma-separated

# --- Proxy (optional) ---
# PROXY_URL=http://user:pass@proxyhost:port
